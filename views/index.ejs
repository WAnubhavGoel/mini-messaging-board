<!DOCTYPE html>
<html lang="en">
    <%- include('head')%>
    <body>
        <%- include('header') %>

        <div class="content">
            <div class="messages-container">
                <a class="add" href="/new">New message</a>
                <ul>
                    <%
                        messages.forEach(message => {%>
                            <%- include('message', {message}) %>
                        <%})
                    %>
                </ul>
            </div>
        </div>
            
        <%- include('footer') %>
    </body>
</html>